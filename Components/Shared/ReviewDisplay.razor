@namespace Leafy_Library.Components.Shared

<div class="review-wrapper">
    <div class="review-author">
        <div class="avatar">@(string.IsNullOrEmpty(ReviewerName) ? "?" : ReviewerName[0..1].ToUpper())</div>
        <span class="author-name">@ReviewerName</span>
    </div>

    <div class="review-content">
        <div class="review-content-header">
            @if (Rating.HasValue)
            {
                <StarRating Rating="@((int)Rating.Value)" Fixed="true" />
            }
            <span class="review-date">@FormatTimestamp(Timestamp)</span>
        </div>
        <p class="review-text">@Text</p>
    </div>
</div>

@code {
    [Parameter] public string ReviewerName { get; set; } = string.Empty;
    [Parameter] public string Text { get; set; } = string.Empty;
    [Parameter] public double? Rating { get; set; }
    [Parameter] public long Timestamp { get; set; }

    private static string FormatTimestamp(long timestampMs)
    {
        if (timestampMs <= 0) return "";
        var dto = DateTimeOffset.FromUnixTimeMilliseconds(timestampMs);
        return dto.ToString("d MMM yyyy");
    }
}
