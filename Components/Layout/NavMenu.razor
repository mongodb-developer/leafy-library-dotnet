<nav class="top-navbar">
    <a class="navbar-brand" href="">
        <img src="leaf-logo.svg" alt="Leafy Library" class="brand-logo" />
        Leafy Library
    </a>

    <input type="checkbox" title="Navigation menu" class="navbar-toggler" id="nav-toggle" />
    <label class="navbar-toggler-label" for="nav-toggle">
        <span class="toggler-icon"></span>
    </label>

    <div class="nav-items">
        <NavLink class="nav-link" href="" Match="NavLinkMatch.All">
            <span class="bi bi-house-door-fill-nav-menu" aria-hidden="true"></span> Home
        </NavLink>

        <AuthorizeView>
            <Authorized>
                @if (context.User.IsInRole("Admin"))
                {
                    <NavLink class="nav-link admin-panel" href="admin">
                        <span class="bi bi-gear-fill-nav-menu" aria-hidden="true"></span>
                        <span>Librarian Dashboard</span>
                    </NavLink>
                }
                <div class="nav-user-section">
                    <NavLink class="nav-link nav-user-info" href="@($"profile/{context.User.Identity?.Name}")">
                        <span class="bi bi-person-fill-nav-menu" aria-hidden="true"></span>
                        <span class="nav-user-name">@context.User.Identity?.Name</span>
                    </NavLink>
                    <button class="btn btn-link nav-link nav-logout-btn" @onclick="Logout">
                        <span class="bi bi-box-arrow-right-nav-menu" aria-hidden="true"></span> Logout
                    </button>
                </div>
            </Authorized>
            <NotAuthorized>
                <NavLink class="nav-link" href="login">
                    <span class="bi bi-person-fill-nav-menu" aria-hidden="true"></span> Login
                </NavLink>
            </NotAuthorized>
        </AuthorizeView>
    </div>
</nav>

@using Leafy_Library.Services
@inject JwtAuthenticationStateProvider AuthStateProvider
@inject NavigationManager Navigation

@code {
    private async Task Logout()
    {
        await AuthStateProvider.LogoutAsync();
        Navigation.NavigateTo("/login");
    }
}