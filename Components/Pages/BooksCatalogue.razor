@page "/"
@page "/books"
@attribute [Authorize]
@using System.Text.RegularExpressions
@inject Leafy_Library.Services.BookService BookService

<PageTitle>Books Catalogue</PageTitle>

<div class="search-bar">
    <input type="text"
           class="form-control search-input"
           placeholder="Search books by title..."
           @bind="searchQuery"
           @bind:event="oninput"
           @bind:after="OnSearchAsync" />
    <span class="search-results-count">@totalCount book(s) found</span>
</div>

<div class="book-card-wrapper">
    @if (books is null)
    {
        <p class="loading-text">Loading books...</p>
    }
    else if (books.Count == 0)
    {
        <p class="loading-text">No books found.</p>
    }
    else
    {
        @foreach (var book in books)
        {
            <div class="book-card">
                <a href="/books/@book.Id">
                    <img class="book-thumbnail"
                         src="@(string.IsNullOrEmpty(book.Cover) ? FallbackImage : book.Cover)"
                         alt="@book.Title" />
                </a>

                <div class="book-card-header">
                    <h3 class="book-title">
                        <a href="/books/@book.Id">@book.Title</a>
                    </h3>
                    <span class="book-authors">
                        by
                        @for (int i = 0; i < book.Authors.Count; i++)
                        {
                            var author = book.Authors[i];
                            <a href="/authors/@author.Id">@author.Name</a>
                            @if (i < book.Authors.Count - 1)
                            {
                                <span>, </span>
                            }
                        }
                    </span>
                </div>

                <div class="book-card-content">
                    @if (IsBookOfTheMonth(book))
                    {
                        <div class="book-details">
                            <span class="book-of-the-month">🏆 Book of the Month selection 🏆</span>
                        </div>
                    }
                    <p class="book-description">@StripHtml(book.Synopsis)</p>
                </div>
            </div>
        }
    }
</div>

@if (totalCount > pageSize)
{
    <div class="pagination">
        <button class="btn btn-primary" disabled="@(currentPage <= 1)" @onclick="PreviousPage">Previous</button>
        <span class="page-info">Page @currentPage of @totalPages</span>
        <button class="btn btn-primary" disabled="@(currentPage >= totalPages)" @onclick="NextPage">Next</button>
    </div>
}

@code {
    private List<Leafy_Library.Models.Book>? books;
    private string searchQuery = string.Empty;
    private int currentPage = 1;
    private int pageSize = 20;
    private long totalCount;
    private int totalPages => (int)Math.Ceiling((double)totalCount / pageSize);

    private const string FallbackImage = "http://lgimages.s3.amazonaws.com/gc-md.gif";

    protected override async Task OnInitializedAsync()
    {
        await LoadBooksAsync();
    }

    private async Task LoadBooksAsync()
    {
        if (string.IsNullOrWhiteSpace(searchQuery))
        {
            books = await BookService.GetAllAsync(currentPage, pageSize);
            totalCount = await BookService.GetCountAsync();
        }
        else
        {
            books = await BookService.SearchAsync(searchQuery, currentPage, pageSize);
            totalCount = await BookService.SearchCountAsync(searchQuery);
        }
    }

    private async Task OnSearchAsync()
    {
        currentPage = 1;
        await LoadBooksAsync();
    }

    private async Task PreviousPage()
    {
        if (currentPage > 1)
        {
            currentPage--;
            await LoadBooksAsync();
        }
    }

    private async Task NextPage()
    {
        if (currentPage < totalPages)
        {
            currentPage++;
            await LoadBooksAsync();
        }
    }

    private static bool IsBookOfTheMonth(Leafy_Library.Models.Book book)
    {
        return book.Attributes.Any(a =>
            a.Key.Equals("bookOfTheMonth", StringComparison.OrdinalIgnoreCase) &&
            a.Value.Equals("true", StringComparison.OrdinalIgnoreCase));
    }

    private static string StripHtml(string? html)
    {
        if (string.IsNullOrWhiteSpace(html)) return string.Empty;
        return Regex.Replace(html, "<[^>]+>", " ").Trim();
    }
}
