@page "/"
@page "/books"
@attribute [Authorize]
@using System.Text.RegularExpressions
@inject BookService BookService

<PageTitle>Books Catalogue</PageTitle>

<div class="search-bar">
    <input type="search"
           class="form-control search-input"
           placeholder="Search books..."
           @bind="searchQuery"
           @bind:event="oninput"
           @bind:after="OnSearchAsync" />
    <div class="search-mode-toggle">
        <button class="toggle-btn @(useSemanticSearch ? "" : "active")" @onclick="() => SetSearchMode(false)">Lexical</button>
        <button class="toggle-btn @(useSemanticSearch ? "active" : "")" @onclick="() => SetSearchMode(true)">Semantic</button>
    </div>
</div>

@if (suggestions.Any())
{
    <ul class="suggestions">
        @foreach (var suggestion in suggestions)
        {
            <li @onclick="() => SelectSuggestionAsync(suggestion)">@suggestion</li>
        }
    </ul>
}

@if (searchResults is not null || hasSearched)
{
    <div class="search-layout">
        @if (!useSemanticSearch)
        {
            <aside class="facets">
                <h3>Filter by genre</h3>
                @if (genreFacets.Any())
                {
                    <ul class="facet-list">
                        <li>
                            <button @onclick="ClearGenreFilterAsync"
                                    class="@(selectedGenre is null ? "active" : "")">
                                All genres
                            </button>
                        </li>
                        @foreach (var (genre, count) in genreFacets)
                        {
                            <li>
                                <button @onclick="() => ApplyGenreFilterAsync(genre)"
                                        class="@(selectedGenre == genre ? "active" : "")">
                                    @genre <span>(@count)</span>
                                </button>
                            </li>
                        }
                    </ul>
                }
            </aside>
        }

        <main class="results">
            @if (searchResults is { Count: > 0 })
            {
                <p class="search-results-count-display">
                    @totalResults result(s) found
                    @if (!string.IsNullOrWhiteSpace(selectedGenre) && !useSemanticSearch)
                    {
                        <span> in <strong>@selectedGenre</strong></span>
                    }
                    @if (useSemanticSearch)
                    {
                        <span> using <strong>Semantic</strong> search</span>
                    }
                </p>
                <div class="search-results-grid">
                    @foreach (var book in searchResults)
                    {
                        <article class="search-result-card">
                            <a href="/books/@book.Id" class="search-result-title">@book.Title</a>
                            <p class="search-result-authors">
                                @string.Join(", ", book.Authors.Select(a => a.Name))
                            </p>
                        </article>
                    }
                </div>
            }
            else if (hasSearched)
            {
                <p>No books found. Try a different search term.</p>
            }
        </main>
    </div>
}
else
{
    <div class="book-card-wrapper">
        @if (books is null)
        {
            <p class="loading-text">Loading books...</p>
        }
        else if (books.Count == 0)
        {
            <p class="loading-text">No books found.</p>
        }
        else
        {
            @foreach (var book in books)
            {
                <div class="book-card">
                    <a href="/books/@book.Id">
                        <img class="book-thumbnail"
                             src="@(string.IsNullOrEmpty(book.Cover) ? FallbackImage : book.Cover)"
                             alt="@book.Title" />
                    </a>

                    <div class="book-card-header">
                        <h3 class="book-title">
                            <a href="/books/@book.Id">@book.Title</a>
                        </h3>
                        <span class="book-authors">
                            by
                            @for (int i = 0; i < book.Authors.Count; i++)
                            {
                                var author = book.Authors[i];
                                <a href="/authors/@author.Id">@author.Name</a>
                                @if (i < book.Authors.Count - 1)
                                {
                                    <span>, </span>
                                }
                            }
                        </span>
                    </div>

                    <div class="book-card-content">
                        @if (IsBookOfTheMonth(book))
                        {
                            <div class="book-details">
                                <span class="book-of-the-month">🏆 Book of the Month selection 🏆</span>
                            </div>
                        }
                        <p class="book-description">@StripHtml(book.Synopsis)</p>
                    </div>
                </div>
            }
        }
    </div>
}

@if (!hasSearched && totalCount > pageSize)
{
    <div class="pagination">
        <button class="btn btn-primary" disabled="@(currentPage <= 1)" @onclick="PreviousPage">Previous</button>
        <span class="page-info">Page @currentPage of @totalPages</span>
        <button class="btn btn-primary" disabled="@(currentPage >= totalPages)" @onclick="NextPage">Next</button>
    </div>
}

@code {
    private List<Book>? books;
    private string searchQuery = string.Empty;
    private List<Book>? searchResults;
    private List<string> suggestions = [];
    private Dictionary<string, int> genreFacets = [];
    private string? selectedGenre;
    private long totalResults;
    private bool hasSearched;
    private int currentPage = 1;
    private int pageSize = 20;
    private long totalCount;
    private int totalPages => (int)Math.Ceiling((double)totalCount / pageSize);
    private bool useSemanticSearch;
    private CancellationTokenSource? _cts;

    private const string FallbackImage = "http://lgimages.s3.amazonaws.com/gc-md.gif";

    protected override async Task OnInitializedAsync()
    {
        await LoadBooksAsync();
    }

    private async Task LoadBooksAsync()
    {
        books = await BookService.GetAllAsync(currentPage, pageSize);
        totalCount = await BookService.GetCountAsync();
    }

    private async Task OnSearchAsync()
    {
        _cts?.Cancel();
        _cts = new CancellationTokenSource();

        if (string.IsNullOrWhiteSpace(searchQuery))
        {
            searchResults = null;
            suggestions = [];
            genreFacets = [];
            selectedGenre = null;
            totalResults = 0;
            hasSearched = false;
            await LoadBooksAsync();
            return;
        }

        try
        {
            await Task.Delay(300, _cts.Token);
            currentPage = 1;

            if (useSemanticSearch)
            {
                suggestions = [];
                genreFacets = [];
                selectedGenre = null;
                searchResults = await BookService.SemanticSearchAsync(searchQuery, currentPage, pageSize);
                totalResults = await BookService.SemanticSearchCountAsync(searchQuery);
            }
            else
            {
                suggestions = await BookService.GetAutocompleteSuggestionsAsync(searchQuery);
                searchResults = await BookService.SearchAsync(searchQuery, currentPage, pageSize);
                totalResults = await BookService.SearchCountAsync(searchQuery);
                genreFacets = await BookService.GetGenreFacetsAsync(searchQuery);
                selectedGenre = null;
            }

            hasSearched = true;
        }
        catch (OperationCanceledException)
        {
            // User typed another character before the delay finished.
        }
    }

    private async Task SetSearchMode(bool semantic)
    {
        useSemanticSearch = semantic;
        if (string.IsNullOrWhiteSpace(searchQuery))
            return;

        currentPage = 1;
        if (useSemanticSearch)
        {
            suggestions = [];
            genreFacets = [];
            selectedGenre = null;
            searchResults = await BookService.SemanticSearchAsync(searchQuery, currentPage, pageSize);
            totalResults = await BookService.SemanticSearchCountAsync(searchQuery);
        }
        else
        {
            suggestions = await BookService.GetAutocompleteSuggestionsAsync(searchQuery);
            searchResults = await BookService.SearchAsync(searchQuery, currentPage, pageSize);
            totalResults = await BookService.SearchCountAsync(searchQuery);
            genreFacets = await BookService.GetGenreFacetsAsync(searchQuery);
            selectedGenre = null;
        }

        hasSearched = true;
    }

    private async Task SelectSuggestionAsync(string title)
    {
        searchQuery = title;
        useSemanticSearch = false;
        currentPage = 1;
        suggestions = [];
        searchResults = await BookService.SearchAsync(title, 1, pageSize);
        totalResults = await BookService.SearchCountAsync(title);
        genreFacets = await BookService.GetGenreFacetsAsync(title);
        selectedGenre = null;
        hasSearched = true;
    }

    private async Task ApplyGenreFilterAsync(string genre)
    {
        selectedGenre = genre;
        currentPage = 1;
        searchResults = await BookService.SearchInGenreAsync(searchQuery, genre, currentPage, pageSize);
        totalResults = await BookService.SearchInGenreCountAsync(searchQuery, genre);
    }

    private async Task ClearGenreFilterAsync()
    {
        selectedGenre = null;
        currentPage = 1;
        searchResults = await BookService.SearchAsync(searchQuery, currentPage, pageSize);
        totalResults = await BookService.SearchCountAsync(searchQuery);
    }

    private async Task PreviousPage()
    {
        if (currentPage > 1)
        {
            currentPage--;
            await LoadBooksAsync();
        }
    }

    private async Task NextPage()
    {
        if (currentPage < totalPages)
        {
            currentPage++;
            await LoadBooksAsync();
        }
    }

    private static bool IsBookOfTheMonth(Book book)
    {
        return book.BookOfTheMonth == true;
    }

    private static string StripHtml(string? html)
    {
        if (string.IsNullOrWhiteSpace(html)) return string.Empty;
        return Regex.Replace(html, "<[^>]+>", " ").Trim();
    }
}
