@page "/books/{BookId}"
@attribute [Authorize]
@using System.Text.RegularExpressions
@inject BookService BookService
@inject ReservationService ReservationService

<PageTitle>@(book?.Title ?? "Book Details")</PageTitle>

@if (book is null)
{
    <p class="loading-text">Loading book details...</p>
}
else
{
    <div class="book-detail">
        <div class="book-detail-header">
            <div class="book-cover-container">
                <img class="book-cover"
                     src="@(string.IsNullOrEmpty(book.Cover) ? FallbackImage : book.Cover)"
                     alt="@book.Title" />
            </div>

            <div class="book-info">
                <h1 class="book-title">@book.Title</h1>

                @if (book.Authors.Count > 0)
                {
                    <p class="book-authors">
                        by
                        @for (int i = 0; i < book.Authors.Count; i++)
                        {
                            var author = book.Authors[i];
                            <a href="/authors/@author.Id">@author.Name</a>
                            @if (i < book.Authors.Count - 1)
                            {
                                <span>, </span>
                            }
                        }
                    </p>
                }

                @if (book.BookOfTheMonth == true)
                {
                    <div class="book-of-the-month-badge">🏆 Book of the Month selection 🏆</div>
                }

                <div class="book-meta">
                    @if (book.Year > 0)
                    {
                        <span class="meta-item"><strong>Year:</strong> @book.Year</span>
                    }
                    @if (book.Pages.HasValue)
                    {
                        <span class="meta-item"><strong>Pages:</strong> @book.Pages</span>
                    }
                    @if (!string.IsNullOrEmpty(book.Publisher))
                    {
                        <span class="meta-item"><strong>Publisher:</strong> @book.Publisher</span>
                    }
                    @if (!string.IsNullOrEmpty(book.Binding))
                    {
                        <span class="meta-item"><strong>Binding:</strong> @book.Binding</span>
                    }
                    @if (!string.IsNullOrEmpty(book.Language))
                    {
                        <span class="meta-item"><strong>Language:</strong> @book.Language</span>
                    }
                </div>

                @if (book.Genres is { Count: > 0 })
                {
                    <div class="book-genres">
                        @foreach (var genre in book.Genres)
                        {
                            <span class="genre-tag">@genre</span>
                        }
                    </div>
                }

                <div class="availability">
                    <h3>Availability</h3>
                    <div class="availability-bar">
                        <span class="available-count @(book.Available > 0 ? "in-stock" : "out-of-stock")">
                            @book.Available available @(book.Available == 1 ? "copy" : "copies")
                        </span>
                        <span class="total-count">of @book.TotalInventory total</span>
                    </div>

                    <AuthorizeView>
                        <Authorized>
                            @if (reservation is not null)
                            {
                                <div class="reservation-active">
                                    <CountDown EndDate="@reservation.ExpirationDate!.Value" />
                                    <button class="btn btn-danger cancel-btn" @onclick="CancelReservation" disabled="@reserving">
                                        Cancel Reservation
                                    </button>
                                </div>
                            }
                            else
                            {
                                <button class="btn btn-primary reserve-btn" @onclick="Reserve"
                                        disabled="@(book.Available <= 0 || reserving)">
                                    @if (reserving)
                                    {
                                        <span>Reserving...</span>
                                    }
                                    else
                                    {
                                        @(book.Available > 0 ? "Reserve this book" : "Currently unavailable")
                                    }
                                </button>
                            }
                        </Authorized>
                    </AuthorizeView>
                </div>
            </div>
        </div>

        @if (!string.IsNullOrWhiteSpace(book.Synopsis))
        {
            <div class="book-synopsis">
                <h2>Synopsis</h2>
                <p>@StripHtml(book.Synopsis)</p>
            </div>
        }

        @if (book.Attributes.Count > 0)
        {
            <div class="book-attributes">
                <h2>Details</h2>
                <table class="attributes-table">
                    <tbody>
                        @foreach (var attr in book.Attributes)
                        {
                            <tr>
                                <td class="attr-key">@attr.Key</td>
                                <td class="attr-value">@attr.Value</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }

        <div class="book-reviews">
            <h2>Reviews</h2>

            <AuthorizeView>
                <Authorized>
                    <ReviewForm BookId="@BookId" UserName="@context.User.Identity?.Name" OnReviewAdded="OnReviewAdded" />
                </Authorized>
            </AuthorizeView>

            @if (book.Reviews.Count == 0)
            {
                <p class="no-reviews">No reviews yet. Be the first to leave a review!</p>
            }
            else
            {
                @foreach (var review in book.Reviews.OrderByDescending(r => r.Timestamp))
                {
                    <ReviewDisplay @key="review.Id"
                                   ReviewerName="@review.Name"
                                   Text="@review.Text"
                                   Rating="@review.Rating"
                                   Timestamp="@review.Timestamp" />
                }
            }
        </div>
    </div>
}

@code {
    [Parameter]
    public string BookId { get; set; } = string.Empty;

    [CascadingParameter] private Task<AuthenticationState> AuthStateTask { get; set; } = null!;

    private Book? book;
    private IssueDetail? reservation;
    private string? userId;
    private string? userName;
    private bool reserving;
    private const string FallbackImage = "http://lgimages.s3.amazonaws.com/gc-md.gif";

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateTask;
        userId = authState.User.FindFirst("sub")?.Value;
        userName = authState.User.Identity?.Name;

        book = await BookService.GetByIdAsync(BookId);

        if (!string.IsNullOrEmpty(userId))
        {
            reservation = await ReservationService.GetReservationAsync(BookId, userId);
        }
    }

    private async Task Reserve()
    {
        if (string.IsNullOrEmpty(userId) || string.IsNullOrEmpty(userName) || reserving) return;

        reserving = true;
        try
        {
            await ReservationService.CreateReservationAsync(BookId, userId, userName);
            await RefreshData();
        }
        catch
        {
            // Reservation failed — refresh to show current state
            await RefreshData();
        }
        finally
        {
            reserving = false;
        }
    }

    private async Task CancelReservation()
    {
        if (string.IsNullOrEmpty(userId) || reserving) return;

        reserving = true;
        try
        {
            await ReservationService.CancelReservationAsync(BookId, userId);
            await RefreshData();
        }
        catch
        {
            await RefreshData();
        }
        finally
        {
            reserving = false;
        }
    }

    private async Task RefreshData()
    {
        book = await BookService.GetByIdAsync(BookId);
        reservation = !string.IsNullOrEmpty(userId)
            ? await ReservationService.GetReservationAsync(BookId, userId)
            : null;
        StateHasChanged();
    }

    private async Task OnReviewAdded()
    {
        book = await BookService.GetByIdAsync(BookId);
        StateHasChanged();
    }

    private static string StripHtml(string? html)
    {
        if (string.IsNullOrWhiteSpace(html)) return string.Empty;
        return Regex.Replace(html, "<[^>]+>", " ").Trim();
    }
}
